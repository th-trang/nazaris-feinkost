rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isStaff() {
      return isSignedIn() && (
        request.auth.token.staff == true ||
        request.auth.token.admin == true
      );
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    match /orders/{orderId} {
      allow read: if isStaff() ||
        (isSignedIn() && resource.data.customerUid == request.auth.uid);

      // Staff can update order status (mark as completed)
      allow update: if isStaff();
      
      // Orders are created by trusted backend Cloud Functions only.
      allow create, delete: if false;
    }

    match /users/{userId} {
      allow read: if isStaff() || (isSignedIn() && request.auth.uid == userId);
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Users can update themselves, admin can update any user
      allow update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow delete: if isStaff();
    }

    match /locations/{locationId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // Internal metadata used by backend functions.
    match /meta/{docId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}